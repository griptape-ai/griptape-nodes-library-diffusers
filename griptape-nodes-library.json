        "category": "Diffusers/Pipeline",
        "description": "Build and cache latent-compatible 🧨 Diffusers Pipelines for reuse across latent execution nodes.",
        "display_name": "Diffusers Pipeline Builder",
        "group": "diffusion"
      }
    },
    {
