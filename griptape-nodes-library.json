        "group": "diffusion"
      }
    },
    {
      "class_name": "LoadLora",
      "file_path": "./diffusers_nodes_library/nodes/load_lora_node.py",
      "metadata": {
        "category": "Diffusers/Pipeline",
        "description": "Load a LoRA file from a local path and expose it as a `loras` output for use with the Diffusers Pipeline Builder.",
        "display_name": "Load LoRA",
        "group": "diffusion"
      }
